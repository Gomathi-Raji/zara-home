# Core
APP_NAME=ZARA AI Backend
APP_VERSION=0.1.0
DEFAULT_MODE=smart

# OpenRouter (primary)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_TIMEOUT_S=10
OPENROUTER_TEMPERATURE=0.65
OPENROUTER_MAX_TOKENS=720

# Ollama (offline fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_FALLBACK_MODEL=gemma2:2b
OLLAMA_TIMEOUT_S=8
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=260

# Voice pipeline
WHISPER_MODEL_SIZE=tiny
WHISPER_MULTILINGUAL_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_AUDIO_SECONDS=8

# Performance tuning
CACHE_TTL_SECONDS=90
CACHE_MAX_ENTRIES=256
MEMORY_LIMIT=12

# Safe automation
AUTOMATION_EXECUTE=false

# Home Automation + MQTT control bridge
HOME_AUTOMATION_DEFAULT=false
HOME_MQTT_ENABLED=true
HOME_MQTT_HOST=127.0.0.1
HOME_MQTT_PORT=1883
HOME_MQTT_KEEPALIVE_S=30
HOME_MQTT_CLIENT_ID=zara-backend
HOME_MQTT_USERNAME=
HOME_MQTT_PASSWORD=
HOME_MQTT_TLS_ENABLED=false
HOME_MQTT_TLS_INSECURE=false
HOME_MQTT_TLS_CA_CERT=
HOME_MQTT_TLS_CERTFILE=
HOME_MQTT_TLS_KEYFILE=
HOME_MQTT_CONTROL_TOPIC=zara/home/control
HOME_MQTT_STATUS_TOPIC=zara/home/status
HOME_MQTT_QOS=1
HOME_MQTT_RETRY_ATTEMPTS=3
HOME_MQTT_RETRY_DELAY_MS=250
HOME_MQTT_PUBLISH_TIMEOUT_S=1.5
HOME_TEMPERATURE_DEFAULT=24
HOME_FAN_SPEED_STEP=10
HOME_FAN_SPEED_MIN=0
HOME_FAN_SPEED_MAX=100
HOME_AC_TEMP_STEP=1
HOME_AC_TEMP_MIN=16
HOME_AC_TEMP_MAX=30

# MCP server bridge (set MCP_ENABLED=true to execute tools remotely)
MCP_ENABLED=false
MCP_TRANSPORT=http
MCP_HTTP_URL=http://127.0.0.1:8099/mcp
MCP_WS_URL=ws://127.0.0.1:8099/mcp
MCP_STDIO_COMMAND=
MCP_AUTH_MODE=none
MCP_AUTH_HEADER=Authorization
MCP_AUTH_TOKEN=
MCP_TIMEOUT_S=8
MCP_OPEN_URL_TOOL=open_url

# Optional Coqui TTS
TTS_ENABLED=false
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC_ph

# Gunicorn
PORT=8000
WEB_CONCURRENCY=1

# Frontend origins allowed to call backend from browser
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173
