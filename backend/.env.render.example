# Render production env template for ZARA backend
# Copy values into Render dashboard Environment variables.

APP_NAME=ZARA AI Backend
APP_VERSION=0.1.0
DEFAULT_MODE=online

# Required secrets
OPENROUTER_API_KEY=replace_me

# Keep TTS off by default for lower memory footprint
TTS_ENABLED=false

# Backend runtime behavior
AUTOMATION_EXECUTE=false
HOME_AUTOMATION_DEFAULT=false
PORT=8000
WEB_CONCURRENCY=1

# CORS must include your Vercel production domain
CORS_ORIGINS=https://zara-aura.vercel.app

# MQTT bridge (use managed broker for internet usage)
HOME_MQTT_ENABLED=true
HOME_MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
HOME_MQTT_PORT=8883
HOME_MQTT_KEEPALIVE_S=30
HOME_MQTT_CLIENT_ID=zara-backend
HOME_MQTT_USERNAME=your-hivemq-username
HOME_MQTT_PASSWORD=your-hivemq-password
HOME_MQTT_TLS_ENABLED=true
HOME_MQTT_TLS_INSECURE=false
HOME_MQTT_TLS_CA_CERT=
HOME_MQTT_TLS_CERTFILE=
HOME_MQTT_TLS_KEYFILE=
HOME_MQTT_CONTROL_TOPIC=zara/home/control
HOME_MQTT_STATUS_TOPIC=zara/home/status
HOME_MQTT_QOS=1
HOME_MQTT_RETRY_ATTEMPTS=3
HOME_MQTT_RETRY_DELAY_MS=250
HOME_MQTT_PUBLISH_TIMEOUT_S=1.5
